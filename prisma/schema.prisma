generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// better-auth core models
// ---------------------------------------------------------------------------

model User {
  id                  String              @id @default(uuid()) @db.Uuid
  name                String
  email               String              @unique
  emailVerified       Boolean             @default(false)
  image               String?
  // username plugin fields
  username            String?             @unique
  displayUsername     String?
  // app-specific fields
  passwordHash        String?
  displayName         String?
  avatarUrl           String?
  status              UserStatus          @default(OFFLINE)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  // better-auth relations
  sessions            Session[]
  accounts            Account[]
  // app relations
  addedContent        Content[]           @relation("AddedContent")
  receivedFriendships Friendship[]        @relation("ReceivedFriendships")
  sentFriendships     Friendship[]        @relation("SentFriendships")
  messages            Message[]
  notifications       Notification[]
  hostedRooms         Room[]              @relation("HostedRooms")
  addedRoomContent    RoomContent[]       @relation("AddedRoomContent")
  memberships         RoomMember[]
  updatedPlaybacks    RoomPlaybackState[] @relation("UpdatedPlaybacks")

  @@index([email])
  @@index([username])
  @@index([deletedAt])
  @@map("user")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime?

  @@map("verification")
}





model Friendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @db.Uuid
  addresseeId String           @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  addressee   User             @relation("ReceivedFriendships", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   User             @relation("SentFriendships", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([requesterId])
  @@index([addresseeId])
  @@index([status])
  @@index([deletedAt])
}

model Room {
  id            String             @id @default(uuid()) @db.Uuid
  name          String
  slug          String             @unique
  description   String?
  hostId        String             @db.Uuid
  visibility    RoomVisibility     @default(PUBLIC)
  passcode      String?
  // new fields
  coverUrl      String?
  contentTitle  String?
  status        RoomStatus         @default(SCHEDULED)
  scheduledAt   DateTime?
  commChat      Boolean            @default(true)
  commAudio     Boolean            @default(false)
  commVideo     Boolean            @default(false)
  inviteToken   String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?
  messages      Message[]
  host          User               @relation("HostedRooms", fields: [hostId], references: [id], onDelete: Cascade)
  roomContents  RoomContent[]
  members       RoomMember[]
  playbackState RoomPlaybackState?

  @@index([hostId])
  @@index([visibility])
  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
}

model RoomMember {
  id         String    @id @default(uuid()) @db.Uuid
  roomId     String    @db.Uuid
  userId     String    @db.Uuid
  role       RoomRole  @default(VIEWER)
  joinedAt   DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  isBanned   Boolean   @default(false)
  isMuted    Boolean   @default(false)
  deletedAt  DateTime?
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([role])
  @@index([deletedAt])
}

model Content {
  id           String        @id @default(uuid()) @db.Uuid
  title        String
  url          String
  type         ContentType
  duration     Int?
  thumbnailUrl String?
  addedById    String?       @db.Uuid
  isPublic     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  addedBy      User?         @relation("AddedContent", fields: [addedById], references: [id])
  roomContents RoomContent[]

  @@index([addedById])
  @@index([type])
  @@index([isPublic])
  @@index([deletedAt])
}

model RoomContent {
  id             String              @id @default(uuid()) @db.Uuid
  roomId         String              @db.Uuid
  contentId      String              @db.Uuid
  queueOrder     Int
  addedById      String              @db.Uuid
  status         RoomContentStatus   @default(QUEUED)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  addedBy        User                @relation("AddedRoomContent", fields: [addedById], references: [id], onDelete: Cascade)
  content        Content             @relation(fields: [contentId], references: [id], onDelete: Cascade)
  room           Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playbackStates RoomPlaybackState[]

  @@index([roomId])
  @@index([contentId])
  @@index([addedById])
  @@index([status])
  @@index([roomId, queueOrder])
  @@index([deletedAt])
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  roomId    String      @db.Uuid
  senderId  String      @db.Uuid
  text      String
  type      MessageType @default(TEXT)
  payload   Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?
  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  payload   Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
}

model RoomPlaybackState {
  id              String       @id @default(uuid()) @db.Uuid
  roomId          String       @unique @db.Uuid
  roomContentId   String?      @db.Uuid
  isPlaying       Boolean      @default(false)
  currentTime     Float        @default(0.0)
  lastUpdatedTime DateTime     @default(now())
  speed           Float        @default(1.0)
  updatedById     String?      @db.Uuid
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  roomContent     RoomContent? @relation(fields: [roomContentId], references: [id])
  room            Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  updatedBy       User?        @relation("UpdatedPlaybacks", fields: [updatedById], references: [id])

  @@index([roomId])
  @@index([roomContentId])
  @@index([updatedById])
}

enum UserStatus {
  ONLINE
  OFFLINE
  IDLE
  DO_NOT_DISTURB
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum RoomStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum RoomRole {
  HOST
  CO_HOST
  MODERATOR
  VIEWER
}

enum ContentType {
  YOUTUBE
  TWITCH
  HLS
  DASH
  MP4
  LIVEKIT
}

enum RoomContentStatus {
  QUEUED
  PLAYING
  PLAYED
  SKIPPED
}

enum MessageType {
  TEXT
  SYSTEM
  EMOJI
  CONTENT_SHARE
}

enum NotificationType {
  FRIEND_REQUEST
  ROOM_INVITE
  PLAYBACK_STARTED
  CHAT_MENTION
  SYSTEM
}
